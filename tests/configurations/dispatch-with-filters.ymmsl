ymmsl_version: v0.2

models:
  dispatch_with_filters:
    components:
      macro:
        description: Macro model
        ports:
          o_i: output disconnected
          s: input from_micro
          o_f: final
      meso:
        description: Meso model
        ports:
          f_init: init
          o_i: output
          s: input
          o_f: final
      micro:
        description: Micro model
        ports:
          f_init: input input2
          o_f: output
      dispatch:
        description: Model that runs after macro and micro
        ports:
          f_init: from_macro from_micro
          o_i: output
          s: input
      micro2:
        description: Micro model for dispatch
        ports:
          f_init: input1 input2
          o_f: output
    conduits:
      macro.output: [meso.init, repeat micro.input2]
      meso.final: [macro.input, last dispatch.from_micro]
      meso.output: micro.input
      micro.output: [meso.input, last last repeat micro2.input1]
      macro.final: dispatch.from_macro
      dispatch.output: micro2.input2
      micro2.output: dispatch.input

