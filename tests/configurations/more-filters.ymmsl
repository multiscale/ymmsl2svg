ymmsl_version: v0.2

models:
  more_filters:
    components:
      macro:
        description: Macro model
        ports:
          f_init: init
          o_i: output
          s: input from_micro
          o_f: final
      meso:
        description: Meso model
        ports:
          f_init: init
          o_i: output
          s: input
          o_f: final
      micro:
        description: Micro model
        ports:
          f_init: input input2
          o_f: output
      micro2:
        description: Micro model for dispatch
        ports:
          f_init: input1 input2
          o_f: output
    ports:
      f_init: init
      o_f: final
      +macro:meso:
        o_i: out
    conduits:
      macro.output: [meso.init, repeat micro.input2, pad micro2.input2]
      meso.final: macro.input
      meso.output: micro.input
      micro.output: [meso.input, micro2.input1]
      micro2.output: [last macro.from_micro, out]
      init: macro.init
      macro.final: final
